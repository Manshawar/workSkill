# ── macOS ────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# ── Node ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── 源码工程 lock 文件(.buildassets 下)──────────────
# 只忽略外置源码工程的 lock,不忽略 skill-install 内任何文件
.buildassets/**/package-lock.json
.buildassets/**/yarn.lock
.buildassets/**/pnpm-lock.yaml

# ── 源码工程构建产物(.buildassets 下)─────────────────
# 外置源码工程的 dist 不入 git;但 skill-install/ui/dist/ 是随包产物,必须保留
.buildassets/**/dist/
.buildassets/**/build/
.buildassets/**/out/
.buildassets/**/*.tsbuildinfo

# ── Build / dist(通用兜底,但不碰随包产物)─────────────
build/
out/
*.tsbuildinfo
# dist/ 不全局忽略 —— skill-install/ui/dist/ 是随包产物,需入 git

# ── Logs ──────────────────────────────────────────────
logs/
*.log

# ── Editor / IDE ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Environment / secrets ─────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── OS / misc ─────────────────────────────────────────
Thumbs.db
Desktop.ini
